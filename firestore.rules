rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funzioni di supporto
    function isAuthenticated() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isAuthenticated() && request.auth.token.email == 'prof.memmo@gmail.com'; 
    }
    
    function isOwner(userId) { 
      return isAuthenticated() && request.auth.uid == userId; 
    }
    
    function isTeacherOrPresident(classId) { 
      return isAuthenticated() && get(/databases/$(database)/documents/classes/$(classId)).data.ownerId == request.auth.uid;
    }

    // Regola globale di default (chiudi tutto)
    match /{document=**} {
      allow read, write: if false;
    }

    // UTENTI: Ognuno legge/scrive il proprio. L'admin fa tutto. I docenti leggono i membri delle loro classi.
    match /users/{userId} {
      allow read: if isAuthenticated(); // Consente di leggere avatar e displayName per classifiche
      allow write: if isOwner(userId) || isAdmin();
    }

    // CONTENUTI DATA-DRIVEN: Lettura per tutti gli autenticati, scrittura solo Admin.
    match /campaigns/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /cases/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /activities/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /badges/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /levels/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /questions/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /characters/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /cantos/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /missions/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // CLASSI e CORTI
    match /classes/{classId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated(); // Qualsiasi docente/giurato può creare una corte
      allow update, delete: if isTeacherOrPresident(classId) || isAdmin();
    }
    
    match /courts/{courtId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated();
      allow update, delete: if isTeacherOrPresident(courtId) || isAdmin(); // La logica è la stessa delle classi
    }

    // SENTENZE E VERDETTI
    match /sentences/{sentenceId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Può leggerla chi l'ha scritta, l'insegnante della classe, o l'admin
      allow read: if isOwner(resource.data.userId) || 
                  isTeacherOrPresident(resource.data.classId) || 
                  isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // LOG XP E PROGRESSI
    match /xpLogs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /progress/{progressId} {
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isOwner(resource.data.userId) || isTeacherOrPresident(resource.data.classId) || isAdmin();
    }
  }
}
